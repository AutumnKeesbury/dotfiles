font_size						14.0scrollback_lines				5000mouse_hide_wait					-3.0remember_window_size			yestab_bar_style 					powerlinetab_powerline_style				roundnotify_on_cmd_finish 			invisible 20cursor_trail					200cursor_trail_decay				0.1 0.4cursor_trail_start_threshold	2
# BEGIN_KITTY_THEME
# Catppuccin-Mocha
include current-theme.conf
# END_KITTY_THEME

# BEGIN_KITTY_FONTS
font_family      family="CaskaydiaCove Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS